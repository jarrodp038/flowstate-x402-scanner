# ══════════════════════════════════════════════════════════════
#   GRADUATION SNIPER BOT — Configuration
#   Copy this file to .env and fill in your values.
#   NEVER commit your real .env file to git.
# ══════════════════════════════════════════════════════════════

# ── PumpDev API ────────────────────────────────────────────────
# Get your free API key at https://pumpdev.io
# The lightning API does server-side signing — no private key needed.
PUMPDEV_API_KEY=your_api_key_here

# ── Solana RPC ─────────────────────────────────────────────────
# Public RPC works but is rate-limited on discovery scans.
# Recommended: Helius (https://helius.dev) — free tier available.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Mode ───────────────────────────────────────────────────────
# true  = paper trading (SAFE — no real transactions)
# false = LIVE trading with real SOL
# Start with true and only switch to false when confident.
TEST_MODE=true

# ── Entry ──────────────────────────────────────────────────────
# SOL to spend per snipe (keep low while learning)
BUY_AMOUNT_SOL=0.05

# Buy when bonding curve hits this completion percentage
# Range: 93-98  |  Lower = earlier entry, more time to wait
#               |  Higher = tighter window, faster graduation
ENTRY_THRESHOLD_PCT=96

# Slippage tolerance in percent (pump.fun can be volatile)
# 20-30% recommended for graduation entries
SLIPPAGE_PCT=25

# ── Exit ───────────────────────────────────────────────────────
# Trailing stop percentage below the high water mark (post-graduation)
# 15% means: if price drops 15% from its highest point → SELL
TRAILING_STOP_PCT=15

# Hard stop loss percentage below entry (pre AND post graduation)
# 30% means: if position drops 30% from entry → emergency SELL
HARD_STOP_LOSS_PCT=30

# Seconds to wait after graduation before trading Raydium/PumpSwap
# Gives the pool time to initialize — don't set below 3000
GRADUATION_DELAY_MS=5000

# ── Risk limits ────────────────────────────────────────────────
# Maximum concurrent open positions
MAX_POSITIONS=3

# Maximum SOL you are willing to lose in a single calendar day
# Bot stops opening new positions once this limit is hit
DAILY_LOSS_LIMIT_SOL=0.15

# ── Monitoring ─────────────────────────────────────────────────
# How often to run the full bonding curve discovery scan (ms)
# Don't set below 15000 on public RPC — you'll get rate limited
SCAN_INTERVAL_MS=30000

# Minimum completion % for a token to be added to the watch list
DISCOVERY_MIN_PCT=85

# Dashboard refresh rate (ms)
DASHBOARD_REFRESH_MS=2000
